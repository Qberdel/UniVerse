    "definitions": {
        "internal_handler.Activity": {
            "description": "Заявка пользователя на модерацию",
            "type": "object",
            "properties": {
                "activity_id": {
                    "type": "integer",
                    "example": 1
                },
                "category_id": {
                    "type": "integer",
                    "example": 1
                },
                "created_at": {
                    "type": "string",
                    "example": "2026-06-09 10:15:30"
                },
                "description": {
                    "type": "string",
                    "example": "Статья по математическому анализу"
                },
                "images": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "https://example.com/img1.jpg"
                    ]
                },
                "name": {
                    "type": "string",
                    "example": "Публикация в журнале ВАК"
                },
                "points_awarded": {
                    "type": "integer",
                    "example": 150
                },
